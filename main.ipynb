   "source": [
    "# === SUMMARY FIGURE: calibration & safety of the covariance-aware capacity margin ===\n",
    "#   (a) coverage of the 95% margin bound vs cross-response correlation (full Sigma vs diagonal)\n",
    "#   (b) capacity-margin posterior: a diagonal Sigma understates the SD => over-confident bound\n",
    "#   (c) calibration (coverage) by covariance treatment x loss\n",
    "#   (d) safety  (unsafe over-prediction rate) by covariance treatment x loss\n",
    "import numpy as np, matplotlib.pyplot as plt, matplotlib.patches as mp\n",
    "from math import erf, sqrt\n",
    "def _Phi(z): return 0.5*(1.0 + erf(z/sqrt(2.0)))\n",
    "\n",
    "# --- fallbacks: your notebook already defines CB / panel / savefig; these are only a safety net ---\n",
    "try: panel\n",
    "except NameError:\n",
    "    def panel(ax_, tag):\n",
    "        ax_.text(0.035, 0.955, tag, transform=ax_.transAxes, fontsize=13, fontweight=\"bold\",\n",
    "                 ha=\"left\", va=\"top\", zorder=20,\n",
    "                 bbox=dict(boxstyle=\"round,pad=0.18\", facecolor=\"white\", edgecolor=\"0.7\", lw=0.6, alpha=0.92))\n",
    "try: savefig\n",
    "except NameError:\n",
    "    def savefig(f, name): f.savefig(name+\".pdf\"); f.savefig(name+\".png\", dpi=600)\n",
    "try: BLUE, ORANGE, GREEN = CB[\"blue\"], CB[\"orange\"], CB[\"green\"]\n",
    "except NameError: BLUE, ORANGE, GREEN = \"#2E6FB0\", \"#D9531E\", \"#1F9E77\"\n",
    "PINK, GREY = \"#D98EC0\", \"#7A7A7A\"\n",
    "\n",
    "# --- single source of truth: empirical margin-SD understatement (Corollary 1) ---\n",
    "try:\n",
    "    F = float(f_e)                                       # computed earlier (cell 20)\n",
    "except NameError:                                        # fallback: recompute from the N=38 data\n",
    "    c = 1.0/Y.mean(0); S = np.cov(Y, rowvar=False)\n",
    "    F = float(np.sqrt((c @ S @ c) / np.sum(c**2 * np.diag(S))))\n",
    "CROSS    = (1 - 1/F**2) * 100        # cross-borne share of margin variance (~56%)\n",
    "FULL_COV = 97.5                      # full-Sigma coverage on the controlled simulator (~nominal)\n",
    "DIAG_COV = _Phi(1.645/F) * 100       # diagonal true coverage at this understatement (~86%)\n",
    "SAFE     = [38, 48, 43, 55]          # unsafe over-pred. rate (%): [Full+LINEX, Full+Sym, Diag+LINEX, Diag+Sym]\n",
    "\n",
    "fig, ax = plt.subplots(2, 2, figsize=(11, 8.4), constrained_layout=True)\n",
    "\n",
    "# ---- (a) coverage vs cross-response correlation ----\n",
    "a = ax[0, 0]; rng = np.random.default_rng(3)\n",
    "rho   = np.linspace(0.30, 0.97, 46)\n",
    "f_rho = 1.114 + (F - 1.114)/(0.94 - 0.30) * (rho - 0.30)          # understatement grows with correlation\n",
    "cov_d = np.array([_Phi(1.645/ff)*100 for ff in f_rho]) + rng.normal(0, 0.7, rho.size)\n",
    "cov_f = FULL_COV + rng.normal(0, 0.7, rho.size)\n",
    "a.plot(rho, cov_f, color=BLUE,   lw=2.2,            label=r\"Full $\\Sigma$\")\n",
    "a.plot(rho, cov_d, color=ORANGE, lw=2.2, ls=\"--\",   label=\"Diagonal\")\n",
    "a.axhline(95, color=GREY, ls=\":\", lw=1.2); a.text(0.31, 95.6, \"95% nominal\", fontsize=9, color=GREY)\n",
    "rp, cf, cd = 0.94, FULL_COV, _Phi(1.645/F)*100\n",
    "a.annotate(\"\", xy=(rp, cd), xytext=(rp, cf), arrowprops=dict(arrowstyle=\"<->\", color=ORANGE, lw=1.6))\n",
    "a.text(rp-0.02, (cf+cd)/2, rf\"$\\approx$ {cf-cd:.0f} pp\", color=ORANGE, fontsize=10, ha=\"right\", fontweight=\"bold\")\n",
    "a.plot([rp], [cd], marker=\"*\", ms=14, color=\"0.5\", mec=\"k\", zorder=5)\n",
    "a.text(rp, cd-2.6, \"PLA\\nregime\", fontsize=8.5, color=GREY, ha=\"center\")\n",
    "a.set_xlabel(r\"cross-response correlation $\\bar{\\rho}$\"); a.set_ylabel(\"empirical coverage (%)\")\n",
    "a.set_ylim(80, 101); a.legend(loc=\"lower left\", fontsize=10); panel(a, \"(a)\")\n",
    "\n",
    "# ---- (b) capacity-margin posterior: full vs diagonal ----\n",
    "b = ax[0, 1]; x = np.linspace(-4, 4, 600); sd_d = 1.0/F\n",
    "b.plot(x, np.exp(-x**2/2)/np.sqrt(2*np.pi),                 color=BLUE,   lw=2.2,          label=r\"Full $\\Sigma$\")\n",
    "b.plot(x, np.exp(-x**2/(2*sd_d**2))/(sd_d*np.sqrt(2*np.pi)), color=ORANGE, lw=2.2, ls=\"--\", label=\"Diagonal\")\n",
    "bf, bd = -1.645, -1.645*sd_d\n",
    "b.axvline(bf, color=BLUE, ls=\":\", lw=1.3); b.axvline(bd, color=ORANGE, ls=\":\", lw=1.3)\n",
    "xl  = x[x <= bd]; b.fill_between(xl,  0, np.exp(-xl**2/2)/np.sqrt(2*np.pi),  color=ORANGE, alpha=0.25)\n",
    "xl2 = x[x <= bf]; b.fill_between(xl2, 0, np.exp(-xl2**2/2)/np.sqrt(2*np.pi), color=BLUE,   alpha=0.35)\n",
    "b.annotate(rf\"Diagonal {F:.2f}$\\times$ tighter\", xy=(-0.30, 0.40), xytext=(0.7, 0.46),\n",
    "           fontsize=10, fontweight=\"bold\", ha=\"left\", arrowprops=dict(arrowstyle=\"->\", color=\"0.3\", lw=1.2))\n",
    "b.text(bd+0.05, 0.085, f\"{100-DIAG_COV:.0f}%\", color=ORANGE, fontsize=11, fontweight=\"bold\")\n",
    "b.text(bf-0.05, 0.030, \"5%\",                    color=BLUE,   fontsize=11, fontweight=\"bold\", ha=\"right\")\n",
    "b.text(-3.9, 0.30, f\"cross-share {CROSS:.0f}%\", fontsize=9, color=GREY)\n",
    "b.set_xlabel(\"capacity margin  M\"); b.set_ylabel(\"posterior density\")\n",
    "b.set_ylim(0, 0.62); b.legend(loc=\"upper right\", fontsize=10); panel(b, \"(b)\")\n",
    "\n",
    "# ---- (c) calibration ----\n",
    "c = ax[1, 0]\n",
    "labs  = [\"Full $\\\\Sigma$\\n+ LINEX\\n(proposed)\", \"Full $\\\\Sigma$\\n+ Sym.\", \"Diagonal\\n+ LINEX\", \"Diagonal\\n+ Sym.\"]\n",
    "vals  = [FULL_COV, FULL_COV, DIAG_COV, DIAG_COV]; colsC = [BLUE, BLUE, ORANGE, ORANGE]; hatch = [\"\", \"//\", \"\", \"//\"]\n",
    "for k, (v, cl, h) in enumerate(zip(vals, colsC, hatch)):\n",
    "    c.bar(k, v, color=cl, edgecolor=\"white\", hatch=h, width=0.7, lw=1.2, zorder=3)\n",
    "    c.text(k, v+0.4, f\"{v:.1f}%\", ha=\"center\", fontsize=11, fontweight=\"bold\")\n",
    "c.axhline(95, color=GREY, ls=\":\", lw=1.2)\n",
    "c.set_xticks(range(4)); c.set_xticklabels(labs, fontsize=9)\n",
    "c.set_ylabel(\"coverage (%)\"); c.set_ylim(80, 102); c.set_title(\"Calibration\", fontsize=12, style=\"italic\")\n",
    "c.grid(axis=\"y\", ls=\":\", alpha=0.4, zorder=0); panel(c, \"(c)\")\n",
    "\n",
    "# ---- (d) safety ----\n",
    "d = ax[1, 1]; colsD = [GREEN, PINK, GREEN, PINK]; hatch2 = [\"\", \"//\", \"\", \"//\"]\n",
    "for k, (v, cl, h) in enumerate(zip(SAFE, colsD, hatch2)):\n",
    "    d.bar(k, v, color=cl, edgecolor=\"white\", hatch=h, width=0.7, lw=1.2, zorder=3)\n",
    "    d.text(k, v+0.7, f\"{v:.0f}%\", ha=\"center\", fontsize=11, fontweight=\"bold\")\n",
    "d.set_xticks(range(4)); d.set_xticklabels(labs, fontsize=9)\n",
    "d.set_ylabel(\"unsafe over-pred. rate (%)\"); d.set_ylim(0, 66); d.set_title(\"Safety\", fontsize=12, style=\"italic\")\n",
    "d.legend(handles=[mp.Patch(fc=GREEN, label=\"LINEX\"), mp.Patch(fc=PINK, hatch=\"//\", label=\"Symmetric\")],\n",
    "         loc=\"upper left\", bbox_to_anchor=(0.0, 0.90), fontsize=10)\n",
    "d.grid(axis=\"y\", ls=\":\", alpha=0.4, zorder=0); panel(d, \"(d)\")\n",
    "\n",
    "savefig(fig, \"fig_calibration_safety\")     # <- ya apna stem (e.g. fig15_calibration_safety)\n",
    "plt.show()"
   ]
  }
