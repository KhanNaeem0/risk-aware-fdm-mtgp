     "text": [
      "ARD relevance (%): {'x1': 26.1, 'x2': 12.0, 'x3': 53.2, 'x4': 8.7}\n"
     ]
    }
   ],
   "source": [
    "# PAPER FIG 9  ->  fig09_ard_relevance.pdf : ARD global relevance of the four process inputs\n",
    "#   relevance_k = (1/lengthscale_k) normalised; geometric (x1,x3) vs thermal/kinematic (x2,x4)\n",
    "lengthscale = FIT[\"m\"].cov.data_covar_module.lengthscale.detach().numpy().ravel()\n",
    "imp = (1.0/lengthscale); imp = imp/imp.sum()*100.0\n",
    "labels = [\"$x_1$  layer thickness\", \"$x_2$  nozzle temp.\",\n",
    "          \"$x_3$  infill density\", \"$x_4$  print speed\"]\n",
    "order = np.argsort(imp)\n",
    "cols  = [CB[\"blue\"], CB[\"lblue\"], CB[\"blue\"], CB[\"lblue\"]]   # geometric vs thermal/kinematic\n",
    "fig, ax = plt.subplots(figsize=(7.2, 4.2), constrained_layout=True)\n",
    "ax.barh(range(4), imp[order], color=[cols[i] for i in order], edgecolor=\"k\", lw=0.6, height=0.66, zorder=3)\n",
    "ax.set_yticks(range(4)); ax.set_yticklabels([labels[i] for i in order])\n",
